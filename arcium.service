[Unit]
Description=Arcium MPC node
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/arx node --config /root/.arcium/config.toml
Restart=always
RestartSec=5
LimitNOFILE=65536
StandardOutput=append:/var/log/arcium.log
StandardError=append:/var/log/arcium.log

[Install]
WantedBy=multi-user.target
